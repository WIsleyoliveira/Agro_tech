# Variáveis de Ambiente - AgroTech Platform

# ===================================
# API do Google Gemini (IA)
# ===================================
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===================================
# Ollama Local (Opcional)
# ===================================
# Se preferir usar Ollama em vez de Gemini
# OLLAMA_BASE_URL=http://localhost:11434

# ===================================
# JWT Secret
# ===================================
# Em produção, use uma chave forte e única
JWT_SECRET=agrotech-super-secret-key-2026-change-me-in-production

# ===================================
# Database (Opcional - para PostgreSQL)
# ===================================
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/agrotech
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=sua-senha
